# =============================================================================
# byrdOS environment variables
# Copy this file to .env and fill in all required values.
# =============================================================================

# -----------------------------------------------------------------------------
# Auth (Auth.js / JWT)
# -----------------------------------------------------------------------------

# AUTH_SECRET — Auth.js secret used for JWT signing and session encryption.
# Generate a 32-byte hex string:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_SECRET=generate-a-random-32-byte-hex-string-here

# AUTH_GOOGLE_ID — Google OAuth client ID (optional; leave blank to disable).
AUTH_GOOGLE_ID=optional-google-oauth-client-id

# AUTH_GOOGLE_SECRET — Google OAuth client secret (optional; leave blank).
AUTH_GOOGLE_SECRET=optional-google-oauth-client-secret

# -----------------------------------------------------------------------------
# Encryption
# -----------------------------------------------------------------------------

# CREDENTIAL_ENCRYPTION_KEY — AES-256-GCM master key for envelope-encrypting
# provider tokens and credentials at rest. Must be a 32-byte hex string.
# Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# This key is never stored in the database. Keep it secret and back it up.
CREDENTIAL_ENCRYPTION_KEY=

# -----------------------------------------------------------------------------
# App
# -----------------------------------------------------------------------------

# WEB_URL — Frontend URL used for CORS origin and callback redirects.
WEB_URL=http://localhost:3000

# PORT — API server port.
PORT=4000

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------

# DATABASE_URL — PostgreSQL connection string.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/byrdos_dev

# -----------------------------------------------------------------------------
# Cache / Queue
# -----------------------------------------------------------------------------

# REDIS_URL — Redis connection string (used by BullMQ and API caching).
REDIS_URL=redis://localhost:6379

# -----------------------------------------------------------------------------
# Provider: Plaid
# -----------------------------------------------------------------------------

# PLAID_CLIENT_ID — Your Plaid client ID.
PLAID_CLIENT_ID=your_plaid_client_id

# PLAID_SECRET — Your Plaid secret for the selected environment.
PLAID_SECRET=your_plaid_secret_sandbox

# PLAID_ENV — Plaid environment: sandbox, development, or production.
PLAID_ENV=sandbox

# PLAID_WEBHOOK_KEY — Plaid webhook verification key (optional for local dev).
PLAID_WEBHOOK_KEY=your_webhook_verification_key
