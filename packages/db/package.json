  },
  "devDependencies": {
    "@byrdos/config": "workspace:*",
    "@byrdos/tsconfig": "workspace:*",
    "@types/node": "^20.17.0",
    "@types/pg": "^8.11.0",
    "@types/uuid": "^10.0.0",
    "drizzle-kit": "^0.30.0",
    "typescript": "^5.7.0"
  }
